{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Triage Output",
  "type": "object",
  "required": ["urgency_score", "urgency_label", "working_hypothesis"],
  "properties": {
    "urgency_score": { "type": "integer", "minimum": 1, "maximum": 5 },
    "urgency_label": {
      "type": "string",
      "enum": ["即時受診", "当日受診", "数日以内受診", "様子見", "経過観察"]
    },
    "working_hypothesis": {
      "type": "array",
      "minItems": 1,
      "maxItems": 3,
      "items": {
        "type": "object",
        "required": ["rank", "condition", "rationale"],
        "properties": {
          "rank": { "type": "integer" },
          "condition": { "type": "string" },
          "rationale": { "type": "string" },
          "category": {
            "type": "string",
            "enum": ["killer_disease", "common_disease", "rare_must_not_miss"]
          }
        }
      }
    },
    "routing": {
      "type": "object",
      "properties": {
        "specialties": { "type": "array", "items": { "type": "string" } },
        "priority_questions": { "type": "array", "items": { "type": "string" } }
      }
    },
    "status": {
      "type": "string",
      "enum": ["ready", "need_more_info"]
    },
    "questions": {
      "type": "array",
      "items": { "type": "string" },
      "description": "status=need_more_info の場合に返す追加質問"
    }
  }
}
